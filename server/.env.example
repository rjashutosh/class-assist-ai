ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_HOST_EMAIL=

# Twilio WhatsApp (sandbox: use whatsapp:+14155238886; set WHATSAPP_TEST_MODE=true to simulate)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
WHATSAPP_TEST_MODE=true