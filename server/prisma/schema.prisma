// ClassAssist Pro - Multi-tenant SaaS (SQLite)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                String        @id @default(cuid())
  subscriptionTier  String        @default("BASIC") // Legacy; prefer Subscription.plan
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  users             User[]
  students          Student[]
  classes           Class[]
  notifications     Notification[]
  subscriptions     Subscription[]
  usageLogs         UsageLog[]
  auditLogs         AuditLog[]

  @@index([id])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   // ADMIN | TEACHER | MANAGER
  accountId String?
  account   Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
}

model Student {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  classes   Class[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
}

model Class {
  id           String   @id @default(cuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Restrict)
  subject      String
  dateTime     DateTime
  status       String   @default("UPCOMING") // UPCOMING | COMPLETED | CANCELLED
  meetingLink  String?
  transcript   String?
  accountId    String
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([accountId])
  @@index([studentId])
  @@index([dateTime])
}

model Notification {
  id         String   @id @default(cuid())
  type       String   // WHATSAPP | MEETING_INVITE | REMINDER
  recipient  String
  message   String
  status     String   @default("PENDING")
  accountId  String
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([accountId])
}

model Subscription {
  id         String   @id @default(cuid())
  accountId  String   @unique
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  plan       String   // BASIC | PRO | ENTERPRISE
  status     String   @default("ACTIVE") // ACTIVE | CANCELLED | PAST_DUE
  startDate  DateTime @default(now())
  endDate    DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([accountId])
  @@index([plan])
}

model UsageLog {
  id        String   @id @default(cuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type      String   // CLASS_CREATED | VOICE_COMMAND | REMINDER_SENT | etc.
  count     Int      @default(0)
  month     Int
  year      Int
  createdAt DateTime @default(now())

  @@unique([accountId, type, month, year])
  @@index([accountId])
  @@index([year, month])
}

model AuditLog {
  id        String   @id @default(cuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  actorId   String   // User id who performed the action
  action    String   // CLASS_CREATED | CLASS_CANCELLED | STUDENT_ADDED | REMINDER_SENT | SUBSCRIPTION_UPDATED | ACCOUNT_CREATED | etc.
  metadata  String?  // JSON string for flexible payload
  createdAt DateTime @default(now())

  @@index([accountId])
  @@index([actorId])
  @@index([createdAt])
}
